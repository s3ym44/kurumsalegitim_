<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-header">
                <a asp-controller="Admin" asp-action="Index" class="sidebar-brand">
                    <div class="sidebar-brand-icon">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <div class="sidebar-brand-text">
                        <span class="brand-name">Kurumsal Eğitim</span>
                        <span class="brand-sub">Admin Panel</span>
                    </div>
                </a>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section">
                    <span class="nav-section-title">Ana Menü</span>
                    <a asp-controller="Admin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="fas fa-tachometer-alt"></i>
                        <span>Dashboard</span>
                    </a>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">İçerik Yönetimi</span>
                    <a asp-controller="Admin" asp-action="Categories" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Categor") == true ? "active" : "")">
                        <i class="fas fa-folder-open"></i>
                        <span>Kategoriler</span>
                    </a>
                    <a asp-controller="Admin" asp-action="Trainings" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Training") == true ? "active" : "")">
                        <i class="fas fa-book-open"></i>
                        <span>Eğitimler</span>
                    </a>
                    <a asp-controller="Admin" asp-action="Events" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Event") == true ? "active" : "")">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Takvim / Etkinlikler</span>
                    </a>
                    <a asp-controller="Admin" asp-action="Announcements" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Announcement") == true ? "active" : "")">
                        <i class="fas fa-bullhorn"></i>
                        <span>Duyurular</span>
                    </a>
                    <a asp-controller="Admin" asp-action="References" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Reference") == true ? "active" : "")">
                        <i class="fas fa-building"></i>
                        <span>Referanslar</span>
                    </a>
                    <a asp-controller="Admin" asp-action="Advantages" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Advantage") == true ? "active" : "")">
                        <i class="fas fa-gift"></i>
                        <span>Avantajlar</span>
                    </a>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">Mail Yönetimi</span>
                    <a asp-controller="Admin" asp-action="Subscribers" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Subscriber") == true ? "active" : "")">
                        <i class="fas fa-users"></i>
                        <span>Aboneler</span>
                    </a>
                    <a asp-controller="Admin" asp-action="MailTemplates" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("MailTemplate") == true ? "active" : "")">
                        <i class="fas fa-envelope-open-text"></i>
                        <span>Mail Şablonları</span>
                    </a>
                    <a asp-controller="Admin" asp-action="BulkMail" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "BulkMail" ? "active" : "")">
                        <i class="fas fa-paper-plane"></i>
                        <span>Toplu Mail</span>
                    </a>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">Hızlı Erişim</span>
                    <a asp-controller="Home" asp-action="Index" target="_blank" class="nav-link">
                        <i class="fas fa-external-link-alt"></i>
                        <span>Siteyi Görüntüle</span>
                    </a>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="admin-main">
            <!-- Top Navbar -->
            <header class="admin-topbar">
                <button class="sidebar-toggle" id="sidebarToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="topbar-right">
                    <span class="topbar-user">
                        <i class="fas fa-user-circle"></i> Admin
                    </span>
                </div>
            </header>

            <!-- Page Content -->
            <main class="admin-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarToggle').addEventListener('click', function () {
            document.querySelector('.admin-wrapper').classList.toggle('sidebar-collapsed');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

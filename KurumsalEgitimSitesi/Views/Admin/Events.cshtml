@model List<KurumsalEgitimSitesi.Models.Event>
@{
    ViewData["Title"] = "Takvim / Etkinlikler";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h1><i class="fas fa-calendar-alt"></i> Takvim / Etkinlikler</h1>
    <a asp-action="EventCreate" class="btn-admin-primary">
        <i class="fas fa-plus"></i> Yeni Etkinlik
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <div style="overflow-x: auto;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Etkinlik Başlığı</th>
                            <th>Tür</th>
                            <th>Başlangıç</th>
                            <th>Bitiş</th>
                            <th>Lokasyon</th>
                            <th>Kontenjan</th>
                            <th>Durum</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><strong>@item.Title</strong></td>
                                <td><span class="badge-type">@item.EventType</span></td>
                                <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@item.EndDate?.ToString("dd MMM yyyy")</td>
                                <td>@item.Location</td>
                                <td>
                                    @if (item.IsLimitedCapacity)
                                    {
                                        <span class="text-danger fw-bold">@item.Capacity kişi</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sınırsız</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-active">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Pasif</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="EventEdit" asp-route-id="@item.Id" class="btn-admin-sm btn-admin-edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="EventDelete" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Bu etkinliği silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-admin-sm btn-admin-delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-calendar-times"></i>
                <p>Henüz etkinlik eklenmemiş.</p>
            </div>
        }
    </div>
</div>

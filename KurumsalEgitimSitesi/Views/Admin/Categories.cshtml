@model List<KurumsalEgitimSitesi.Models.Category>
@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h1><i class="fas fa-folder-open"></i> Kategoriler</h1>
    <a asp-action="CategoryCreate" class="btn-admin-primary">
        <i class="fas fa-plus"></i> Yeni Kategori
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>İkon</th>
                        <th>Kategori Adı</th>
                        <th>Açıklama</th>
                        <th>Renk</th>
                        <th>Sıra</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><i class="@item.IconClass" style="color: @item.ColorCode; font-size: 1.2rem;"></i></td>
                            <td><strong>@item.Name</strong></td>
                            <td style="max-width: 250px;">@(item.Description?.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)</td>
                            <td><span class="color-preview" style="background: @item.ColorCode;"></span>@item.ColorCode</td>
                            <td>@item.SortOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge-active">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge-inactive">Pasif</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="CategoryEdit" asp-route-id="@item.Id" class="btn-admin-sm btn-admin-edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="CategoryDelete" asp-route-id="@item.Id" method="post" 
                                          onsubmit="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-admin-sm btn-admin-delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-folder-open"></i>
                <p>Henüz kategori eklenmemiş.</p>
            </div>
        }
    </div>
</div>

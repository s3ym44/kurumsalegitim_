@model List<KurumsalEgitimSitesi.Models.Reference>
@{
    ViewData["Title"] = "Referanslar";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h1><i class="fas fa-building"></i> Referanslar</h1>
    <a asp-action="ReferenceCreate" class="btn-admin-primary">
        <i class="fas fa-plus"></i> Yeni Referans
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>İkon</th>
                        <th>Kurum Adı</th>
                        <th>Sektör</th>
                        <th>Açıklama</th>
                        <th>Sıra</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><i class="@item.IconClass" style="font-size: 1.2rem;"></i></td>
                            <td><strong>@item.CompanyName</strong></td>
                            <td><span class="badge-type">@item.Sector</span></td>
                            <td>@item.Description</td>
                            <td>@item.SortOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge-active">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge-inactive">Pasif</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="ReferenceEdit" asp-route-id="@item.Id" class="btn-admin-sm btn-admin-edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="ReferenceDelete" asp-route-id="@item.Id" method="post"
                                          onsubmit="return confirm('Bu referansı silmek istediğinize emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-admin-sm btn-admin-delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-building"></i>
                <p>Henüz referans eklenmemiş.</p>
            </div>
        }
    </div>
</div>

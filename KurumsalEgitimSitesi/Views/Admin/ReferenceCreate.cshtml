@model KurumsalEgitimSitesi.Models.Reference
@{
    ViewData["Title"] = "Yeni Referans";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h1><i class="fas fa-plus-circle"></i> Yeni Referans</h1>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <form asp-action="ReferenceCreate" method="post" class="admin-form">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CompanyName" class="form-label"></label>
                    <input asp-for="CompanyName" class="form-control" placeholder="Kurum adı" />
                    <span asp-validation-for="CompanyName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Sector" class="form-label"></label>
                    <select asp-for="Sector" class="form-select">
                        <option value="">Sektör Seçin</option>
                        <option value="Kamu">Kamu</option>
                        <option value="Özel Sektör">Özel Sektör</option>
                        <option value="Belediye">Belediye</option>
                    </select>
                </div>
                <div class="col-md-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Açıklama"></textarea>
                </div>
                <div class="col-md-4">
                    <label asp-for="IconClass" class="form-label"></label>
                    <input asp-for="IconClass" class="form-control" placeholder="fas fa-landmark" />
                    <small class="text-muted">Font Awesome ikon sınıfı</small>
                </div>
                <div class="col-md-4">
                    <label asp-for="LogoUrl" class="form-label"></label>
                    <input asp-for="LogoUrl" class="form-control" placeholder="https://..." />
                </div>
                <div class="col-md-4">
                    <label asp-for="SortOrder" class="form-label"></label>
                    <input asp-for="SortOrder" class="form-control" type="number" />
                </div>
                <div class="col-md-6">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> Kaydet</button>
                <a asp-action="References" class="btn-admin-back"><i class="fas fa-arrow-left"></i> Geri Dön</a>
            </div>
        </form>
    </div>
</div>

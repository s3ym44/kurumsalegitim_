@model List<KurumsalEgitimSitesi.Models.PartnerAdvantage>
@{
    ViewData["Title"] = "Katılımcı Avantajları";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h1><i class="fas fa-gift"></i> Katılımcı Avantajları</h1>
    <a asp-action="AdvantageCreate" class="btn-admin-primary"><i class="fas fa-plus"></i> Yeni Avantaj</a>
</div>

<div class="admin-card">
    <div class="admin-card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <div style="overflow-x: auto;">
                <table class="admin-table">
                    <thead>
                        <tr><th>#</th><th>Partner</th><th>Avantaj</th><th>Kategori</th><th>İndirim</th><th>Sıra</th><th>Durum</th><th>İşlemler</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><strong>@item.PartnerName</strong></td>
                                <td>@item.Title</td>
                                <td><span class="badge-type">@item.Category</span></td>
                                <td><strong>@item.DiscountDetail</strong></td>
                                <td>@item.SortOrder</td>
                                <td>@(item.IsActive ? Html.Raw("<span class='badge-active'>Aktif</span>") : Html.Raw("<span class='badge-inactive'>Pasif</span>"))</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="AdvantageEdit" asp-route-id="@item.Id" class="btn-admin-sm btn-admin-edit"><i class="fas fa-edit"></i></a>
                                        <form asp-action="AdvantageDelete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-admin-sm btn-admin-delete"><i class="fas fa-trash-alt"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state"><i class="fas fa-gift"></i><p>Henüz avantaj eklenmemiş.</p></div>
        }
    </div>
</div>

@model KurumsalEgitimSitesi.Models.MailTemplate
@{
    ViewData["Title"] = "Mail Şablonu Düzenle";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h1><i class="fas fa-edit"></i> Mail Şablonu Düzenle</h1>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <form asp-action="MailTemplateEdit" asp-route-id="@Model.Id" method="post" class="admin-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Subject" class="form-label"></label>
                    <input asp-for="Subject" class="form-control" />
                    <span asp-validation-for="Subject" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="HtmlBody" class="form-label"></label>
                    <textarea asp-for="HtmlBody" class="form-control" rows="12"></textarea>
                    <small class="text-muted">Kullanılabilir değişkenler: <code>{{name}}</code>, <code>{{email}}</code></small>
                    <span asp-validation-for="HtmlBody" class="text-danger small"></span>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> Güncelle</button>
                <a asp-action="MailTemplates" class="btn-admin-back"><i class="fas fa-arrow-left"></i> Geri Dön</a>
            </div>
        </form>
    </div>
</div>

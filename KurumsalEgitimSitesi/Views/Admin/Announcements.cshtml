@model List<KurumsalEgitimSitesi.Models.Announcement>
@{
    ViewData["Title"] = "Duyurular";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h1><i class="fas fa-bullhorn"></i> Duyurular</h1>
    <a asp-action="AnnouncementCreate" class="btn-admin-primary">
        <i class="fas fa-plus"></i> Yeni Duyuru
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body" style="padding: 0;">
        @if (Model.Any())
        {
            <div style="overflow-x: auto;">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Başlık</th>
                            <th>Tür</th>
                            <th>Yazar</th>
                            <th>Yayın Tarihi</th>
                            <th>Durum</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    <strong>@item.Title</strong>
                                    @if (!string.IsNullOrEmpty(item.Summary))
                                    {
                                        <br><small class="text-muted">@(item.Summary.Length > 80 ? item.Summary.Substring(0, 80) + "..." : item.Summary)</small>
                                    }
                                </td>
                                <td><span class="badge-type">@item.Type</span></td>
                                <td>@item.Author</td>
                                <td>@item.PublishDate?.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.IsPublished)
                                    {
                                        <span class="badge-active">Yayında</span>
                                    }
                                    else
                                    {
                                        <span class="badge-inactive">Taslak</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="AnnouncementEdit" asp-route-id="@item.Id" class="btn-admin-sm btn-admin-edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="AnnouncementDelete" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-admin-sm btn-admin-delete">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-bullhorn"></i>
                <p>Henüz duyuru eklenmemiş.</p>
            </div>
        }
    </div>
</div>

@model KurumsalEgitimSitesi.Models.MailTemplate
@{
    ViewData["Title"] = "Yeni Mail Şablonu";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <h1><i class="fas fa-plus-circle"></i> Yeni Mail Şablonu</h1>
</div>

<div class="admin-card">
    <div class="admin-card-body">
        <form asp-action="MailTemplateCreate" method="post" class="admin-form">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Şablon adı" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Subject" class="form-label"></label>
                    <input asp-for="Subject" class="form-control" placeholder="E-posta konusu" />
                    <span asp-validation-for="Subject" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="HtmlBody" class="form-label"></label>
                    <textarea asp-for="HtmlBody" class="form-control" rows="12" placeholder="HTML içerik..."></textarea>
                    <small class="text-muted">Kullanılabilir değişkenler: <code>{{name}}</code>, <code>{{email}}</code></small>
                    <span asp-validation-for="HtmlBody" class="text-danger small"></span>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label asp-for="IsActive" class="form-check-label">Aktif</label>
                    </div>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> Kaydet</button>
                <a asp-action="MailTemplates" class="btn-admin-back"><i class="fas fa-arrow-left"></i> Geri Dön</a>
            </div>
        </form>
    </div>
</div>

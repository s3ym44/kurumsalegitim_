@model KurumsalEgitimSitesi.Models.Announcement
@{
    ViewData["Title"] = Model.Title;
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1 class="page-header-title" data-aos="fade-up">@Model.Title</h1>
        <div class="breadcrumb-custom" data-aos="fade-up" data-aos-delay="100">
            <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
            <span>/</span>
            <a asp-controller="Home" asp-action="Blog">Blog & Duyurular</a>
            <span>/</span>
            <span>@Model.Title</span>
        </div>
    </div>
</section>

<!-- Content -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded-3 mb-4 w-100" style="max-height: 400px; object-fit: cover;" data-aos="fade-up" />
                }

                @if (!string.IsNullOrEmpty(Model.Summary))
                {
                    <p class="lead text-muted mb-4" style="font-size: 1.1rem; line-height: 1.8; border-left: 4px solid #2563eb; padding-left: 1rem;" data-aos="fade-up">
                        @Model.Summary
                    </p>
                }

                <div class="blog-content" style="font-size: 1rem; line-height: 1.9; color: #374151;" data-aos="fade-up">
                    @Html.Raw(Model.Content.Replace("\n", "<br/>"))
                </div>

                <!-- Share & Back -->
                <div class="d-flex justify-content-between align-items-center mt-5 pt-4" style="border-top: 1px solid #e5e7eb;" data-aos="fade-up">
                    <a asp-controller="Home" asp-action="Blog" class="text-decoration-none fw-bold" style="color: #2563eb;">
                        <i class="fas fa-arrow-left me-1"></i> Tüm Yazılar
                    </a>
                    <div class="d-flex gap-2">
                        <span class="text-muted small me-2" style="line-height: 2;">Paylaş:</span>
                        <a href="#" class="btn btn-sm" style="background: #eff6ff; color: #2563eb; border-radius: 8px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="#" class="btn btn-sm" style="background: #eff6ff; color: #2563eb; border-radius: 8px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                            <i class="fab fa-twitter"></i>
                        </a>
                        <a href="#" class="btn btn-sm" style="background: #eff6ff; color: #2563eb; border-radius: 8px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;">
                            <i class="fab fa-linkedin-in"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Related Posts -->
        @{
            var recentPosts = ViewBag.RecentPosts as List<KurumsalEgitimSitesi.Models.Announcement>;
        }
        @if (recentPosts != null && recentPosts.Any())
        {
            <div class="mt-5 pt-5" style="border-top: 1px solid #e5e7eb;">
                <h3 class="fw-bold text-center mb-4" data-aos="fade-up">Diğer Yazılar</h3>
                <div class="row g-4 justify-content-center">
                    @foreach (var post in recentPosts)
                    {
                        <div class="col-lg-4 col-md-6" data-aos="fade-up">
                            <div class="card border-0 shadow-sm h-100" style="border-radius: 12px; overflow: hidden;">
                                <div style="height: 140px; background: linear-gradient(135deg, @(post.Type == "Blog" ? "#7c3aed, #a78bfa" : post.Type == "Haber" ? "#059669, #34d399" : "#2563eb, #60a5fa")); display: flex; align-items: center; justify-content: center;">
                                    <i class="@(post.Type == "Blog" ? "fas fa-pen-fancy" : post.Type == "Haber" ? "fas fa-newspaper" : "fas fa-bullhorn") fa-2x text-white opacity-50"></i>
                                </div>
                                <div class="card-body p-3">
                                    <span class="badge mb-2" style="background: #eff6ff; color: #2563eb; font-size: 0.7rem;">@post.Type</span>
                                    <h6 class="fw-bold mb-2">@post.Title</h6>
                                    <a asp-controller="Home" asp-action="BlogDetail" asp-route-id="@post.Id" class="text-decoration-none small fw-bold" style="color: #2563eb;">
                                        Devamını Oku <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

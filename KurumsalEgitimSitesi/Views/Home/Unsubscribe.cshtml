@{
    ViewData["Title"] = "Abonelik İptali";
}

<section class="page-header">
    <div class="container">
        <h1 class="page-header-title" data-aos="fade-up">Abonelik İptali</h1>
        <div class="breadcrumb-custom" data-aos="fade-up" data-aos-delay="100">
            <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
            <span>/</span>
            <span>Abonelik İptali</span>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                    <div class="card-body p-5">
                        <i class="fas fa-envelope-open fa-3x mb-3" style="color: #94a3b8;"></i>
                        <h4 class="fw-bold mb-3">Aboneliğiniz İptal Edildi</h4>
                        <p class="text-muted mb-4">
                            <strong>@ViewBag.Email</strong> adresi bülten listemizden çıkarılmıştır.
                            Artık e-posta almayacaksınız.
                        </p>
                        <a asp-controller="Home" asp-action="Index" class="btn px-4 py-2" style="background: linear-gradient(135deg, #2563eb, #3b82f6); color: white; border-radius: 8px;">
                            <i class="fas fa-home me-1"></i> Ana Sayfaya Dön
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

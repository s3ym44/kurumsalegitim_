@{
    ViewData["Title"] = "Hakkımızda";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1 class="page-header-title" data-aos="fade-up">Hakkımızda</h1>
        <div class="breadcrumb-custom" data-aos="fade-up" data-aos-delay="100">
            <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
            <span>/</span>
            <span>Hakkımızda</span>
        </div>
    </div>
</section>

<!-- About Content Section -->
<section class="section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-right">
                <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop" 
                     alt="Kurumsal Eğitim" class="img-fluid rounded-3 shadow">
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <span class="section-badge">Biz Kimiz?</span>
                <h2 style="font-size: 1.75rem; font-weight: 700; color: #1f2937; margin-bottom: 1rem;">
                    Kamu ve Özel Kurumların Güvenilir Eğitim Partneri
                </h2>
                <p style="font-size: 0.95rem; line-height: 1.8; color: #6b7280; margin-bottom: 1.5rem;">
                    12 yılı aşkın tecrübemiz ile kamu kurumları ve özel sektöre yönelik 
                    kapsamlı kurumsal eğitim çözümleri sunuyoruz. Bakanlıklar, belediyeler, kamu kurum ve 
                    kuruluşları ile özel sektör firmalarına eğitim veren uzman kadromuz, sektörün en 
                    deneyimli isimlerinden oluşmaktadır.
                </p>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-check-circle me-2" style="color: #2563eb;"></i>
                            <span style="font-size: 0.9rem;">Kamu Tecrübesi</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-check-circle me-2" style="color: #2563eb;"></i>
                            <span style="font-size: 0.9rem;">Akredite Eğitimler</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-check-circle me-2" style="color: #2563eb;"></i>
                            <span style="font-size: 0.9rem;">Uzman Kadro</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-check-circle me-2" style="color: #2563eb;"></i>
                            <span style="font-size: 0.9rem;">Online/Yüz yüze</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Statistics -->
<section class="section" style="background: var(--gray-50);">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                    <div class="stat-number">15.000+</div>
                    <div class="stat-label">Eğitilen Personel</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-building"></i></div>
                    <div class="stat-number">250+</div>
                    <div class="stat-label">Kurum & Kuruluş</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-trophy"></i></div>
                    <div class="stat-number">12+</div>
                    <div class="stat-label">Yıl Deneyim</div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-certificate"></i></div>
                    <div class="stat-number">50+</div>
                    <div class="stat-label">Eğitim Programı</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Certifications Section -->
<section class="section">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <span class="section-badge">Akreditasyonlarımız</span>
            <h2 class="section-title">Sertifikalar ve Yetki Belgelerimiz</h2>
            <p class="section-subtitle">
                Ulusal ve uluslararası standartlarda akredite eğitim hizmeti sunuyoruz.
            </p>
        </div>
        
        <div class="row g-4 justify-content-center">
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="trust-card text-center">
                    <div class="trust-icon mx-auto">
                        <i class="fas fa-award"></i>
                    </div>
                    <h4 class="trust-title">ISO 9001:2015</h4>
                    <p class="trust-desc">Kalite Yönetim Sistemi Sertifikası</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="trust-card text-center">
                    <div class="trust-icon mx-auto">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h4 class="trust-title">MEB Onaylı</h4>
                    <p class="trust-desc">Milli Eğitim Bakanlığı Onaylı Programlar</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="trust-card text-center">
                    <div class="trust-icon mx-auto">
                        <i class="fas fa-shield-alt"></i>
                    </div>
                    <h4 class="trust-title">TÜRKAK</h4>
                    <p class="trust-desc">Türk Akreditasyon Kurumu Belgeli</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="trust-card text-center">
                    <div class="trust-icon mx-auto">
                        <i class="fas fa-certificate"></i>
                    </div>
                    <h4 class="trust-title">TSE Belgeli</h4>
                    <p class="trust-desc">Türk Standartları Enstitüsü Belgesi</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Vision Mission Section -->
<section class="section-blue" style="padding: 5rem 0;">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <span class="section-badge">Vizyonumuz & Misyonumuz</span>
            <h2 class="section-title">Hedeflerimiz</h2>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                <div class="trust-card" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);">
                    <div class="trust-icon mx-auto" style="background: linear-gradient(135deg, #f97316, #fb923c);">
                        <i class="fas fa-eye"></i>
                    </div>
                    <h4 class="trust-title text-center" style="color: white;">Vizyonumuz</h4>
                    <p class="trust-desc text-center" style="color: rgba(255,255,255,0.75);">
                        Türkiye'nin kamu ve özel sektör kurumlarının tercih ettiği, 
                        güvenilir ve kaliteli kurumsal eğitim partneri olmak.
                    </p>
                </div>
            </div>
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="200">
                <div class="trust-card" style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);">
                    <div class="trust-icon mx-auto" style="background: linear-gradient(135deg, #2563eb, #3b82f6);">
                        <i class="fas fa-bullseye"></i>
                    </div>
                    <h4 class="trust-title text-center" style="color: white;">Misyonumuz</h4>
                    <p class="trust-desc text-center" style="color: rgba(255,255,255,0.75);">
                        Kurumların ihtiyaçlarına özel tasarlanmış, ölçülebilir ve 
                        sürdürülebilir eğitim programları ile çalışanların yetkinliklerini artırmak.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="section">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <span class="section-badge">Değerlerimiz</span>
            <h2 class="section-title">Temel İlkelerimiz</h2>
        </div>
        
        <div class="row g-4">
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <div class="category-card text-center">
                    <div class="category-icon mx-auto">
                        <i class="fas fa-gem"></i>
                    </div>
                    <h3 class="category-title">Kalite</h3>
                    <p class="category-desc">En yüksek kalite standartlarında eğitim</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <div class="category-card text-center">
                    <div class="category-icon mx-auto">
                        <i class="fas fa-balance-scale"></i>
                    </div>
                    <h3 class="category-title">Güvenilirlik</h3>
                    <p class="category-desc">Şeffaf iletişim ve zamanında teslimat</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <div class="category-card text-center">
                    <div class="category-icon mx-auto">
                        <i class="fas fa-cogs"></i>
                    </div>
                    <h3 class="category-title">Özelleştirme</h3>
                    <p class="category-desc">Her kuruma özel tasarlanmış içerikler</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <div class="category-card text-center">
                    <div class="category-icon mx-auto">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3 class="category-title">Ölçülebilirlik</h3>
                    <p class="category-desc">Eğitim öncesi ve sonrası değerlendirmeler</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="section-blue" style="padding: 4rem 0; margin-bottom: 4rem;">
    <div class="container text-center" data-aos="fade-up">
        <h2 style="font-size: 2rem; font-weight: 700; color: white; margin-bottom: 0.75rem;">Kurumunuz İçin Eğitim Planlayalım</h2>
        <p style="color: rgba(255,255,255,0.85); margin-bottom: 1.5rem;">
            Eğitim ihtiyaçlarınızı birlikte değerlendirelim
        </p>
        <a asp-controller="Home" asp-action="Contact" class="btn-hero-primary">
            <i class="fas fa-envelope me-2"></i>İletişime Geçin
        </a>
    </div>
</section>

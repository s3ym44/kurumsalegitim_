@model List<KurumsalEgitimSitesi.Models.Event>
@{
    ViewData["Title"] = "Eğitim Takvimi";
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1 class="page-header-title" data-aos="fade-up">Eğitim Takvimi</h1>
        <div class="breadcrumb-custom" data-aos="fade-up" data-aos-delay="100">
            <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
            <span>/</span>
            <span>Eğitim Takvimi</span>
        </div>
    </div>
</section>

<!-- Filter Tabs -->
<section class="py-4">
    <div class="container">
        <div class="d-flex flex-wrap gap-2 mb-4 justify-content-center" data-aos="fade-up">
            <button class="btn btn-filter active" onclick="filterEvents('all', this)">Tümü</button>
            <button class="btn btn-filter" onclick="filterEvents('Seminer', this)">Seminerler</button>
            <button class="btn btn-filter" onclick="filterEvents('Eğitim', this)">Eğitimler</button>
            <button class="btn btn-filter" onclick="filterEvents('Konferans', this)">Konferanslar</button>
            <button class="btn btn-filter" onclick="filterEvents('Workshop', this)">Workshop</button>
        </div>

        @{
            var upcoming = Model.Where(e => e.StartDate >= DateTime.UtcNow).ToList();
            var past = Model.Where(e => e.StartDate < DateTime.UtcNow).ToList();
        }

        @if (Model.Any())
        {
            @if (upcoming.Any())
            {
                <h3 class="fw-bold mb-4" data-aos="fade-up"><i class="fas fa-calendar-check text-primary me-2"></i>Yaklaşan Etkinlikler</h3>
                <div class="row g-5 mb-5" style="row-gap: 2.5rem;">
                    @foreach (var item in upcoming)
                    {
                        <div class="col-lg-4 col-md-6 event-card" data-type="@item.EventType" data-aos="fade-up">
                            <div class="card border-0 h-100 overflow-hidden" style="border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); border: 1px solid #e2e8f0;">
                                <div class="card-body p-0">
                                    <div style="background: linear-gradient(135deg, #2563eb, #06b6d4); padding: 1.25rem; color: white;">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <span class="badge bg-white text-primary fw-bold mb-2">@item.EventType</span>
                                                @if (item.IsLimitedCapacity)
                                                {
                                                    <span class="badge bg-danger ms-1">Sınırlı Kontenjan</span>
                                                }
                                            </div>
                                        </div>
                                        <h5 class="fw-bold mt-2 mb-0">@item.Title</h5>
                                    </div>
                                    <div class="p-4">
                                        <div class="d-flex align-items-center mb-3">
                                            <div style="width: 40px; height: 40px; background: #eff6ff; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 12px;">
                                                <i class="fas fa-calendar-alt text-primary"></i>
                                            </div>
                                            <div>
                                                <small class="text-muted d-block">Tarih</small>
                                                <strong>@item.StartDate.ToString("dd MMMM yyyy")</strong>
                                                @if (item.EndDate.HasValue)
                                                {
                                                    <span> - @item.EndDate.Value.ToString("dd MMMM yyyy")</span>
                                                }
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Location))
                                        {
                                            <div class="d-flex align-items-center mb-3">
                                                <div style="width: 40px; height: 40px; background: #fef3c7; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 12px;">
                                                    <i class="fas fa-map-marker-alt text-warning"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block">Lokasyon</small>
                                                    <strong>@item.Location</strong>
                                                </div>
                                            </div>
                                        }
                                        @if (item.Capacity.HasValue)
                                        {
                                            <div class="d-flex align-items-center mb-3">
                                                <div style="width: 40px; height: 40px; background: #fce7f3; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-right: 12px;">
                                                    <i class="fas fa-users text-danger"></i>
                                                </div>
                                                <div>
                                                    <small class="text-muted d-block">Kontenjan</small>
                                                    <strong>@item.Capacity kişi</strong>
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <p class="text-muted small mt-3 mb-3">@(item.Description.Length > 150 ? item.Description.Substring(0, 150) + "..." : item.Description)</p>
                                        }
                                        <a asp-controller="Home" asp-action="Contact" class="btn w-100" style="background: linear-gradient(135deg, #2563eb, #3b82f6); color: white; border-radius: 8px; font-weight: 500;">
                                            <i class="fas fa-paper-plane me-1"></i> Başvuru Yap
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (past.Any())
            {
                <h3 class="fw-bold mb-4" data-aos="fade-up"><i class="fas fa-history text-muted me-2"></i>Geçmiş Etkinlikler</h3>
                <div class="row g-4" style="row-gap: 1.5rem;">
                    @foreach (var item in past)
                    {
                        <div class="col-lg-4 col-md-6 event-card" data-type="@item.EventType" data-aos="fade-up">
                            <div class="card border-0 h-100" style="border-radius: 16px; background: #ffffff; box-shadow: 0 6px 30px rgba(0,0,0,0.12); border: none;">
                                <div class="card-body p-4">
                                    <span class="badge bg-secondary mb-2">@item.EventType</span>
                                    <h5 class="fw-bold">@item.Title</h5>
                                    <div class="d-flex align-items-center text-muted small mb-2">
                                        <i class="fas fa-calendar-alt me-2"></i>
                                        @item.StartDate.ToString("dd MMMM yyyy")
                                        @if (item.EndDate.HasValue)
                                        {
                                            <span>&nbsp;- @item.EndDate.Value.ToString("dd MMMM yyyy")</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Location))
                                    {
                                        <div class="d-flex align-items-center text-muted small">
                                            <i class="fas fa-map-marker-alt me-2"></i>
                                            @item.Location
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">Henüz etkinlik bulunmuyor.</h4>
                <p class="text-muted">Yakında yeni etkinlikler eklenecektir.</p>
            </div>
        }
    </div>
</section>

<!-- CTA -->
<section style="background: linear-gradient(135deg, #0f172a, #1e3a5f); padding: 4rem 0; margin-bottom: 4rem; border-radius: 16px;">
    <div class="container text-center text-white">
        <h3 class="fw-bold mb-3" style="color: #ffffff;" data-aos="fade-up">Özel Eğitim Talebi</h3>
        <p class="opacity-75 mb-4" data-aos="fade-up" data-aos-delay="100">Kurumunuza özel eğitim programları için bizimle iletişime geçin.</p>
        <a asp-controller="Home" asp-action="Contact" class="btn btn-lg px-5 py-3" style="background: linear-gradient(135deg, #f97316, #ea580c); color: white; border-radius: 8px; font-weight: 600;" data-aos="fade-up" data-aos-delay="200">
            <i class="fas fa-envelope me-2"></i> İletişime Geç
        </a>
    </div>
</section>

@section Scripts {
<style>
    .calendar-section {
        background: transparent;
        border-radius: 0;
        box-shadow: none;
    }
    .btn-filter {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 20px;
        padding: 0.4rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.3s;
    }
    .btn-filter:hover, .btn-filter.active {
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        color: white;
        border-color: #2563eb;
    }
    .event-card .card {
        transition: all 0.3s ease;
    }
    .event-card .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.15) !important;
    }
</style>
<script>
    function filterEvents(type, btn) {
        document.querySelectorAll('.btn-filter').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.event-card').forEach(card => {
            if (type === 'all' || card.dataset.type === type) {
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
    }
</script>
}
